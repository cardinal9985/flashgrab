Output demo.gif

Set Shell "bash"
Set FontSize 16
Set Width 900
Set Height 500
Set Theme "Catppuccin Mocha"
Set Padding 20
Set TypingSpeed 80ms

# Launch flashgrab
Type "flashgrab"
Enter
Sleep 2s

# Paste a Newgrounds URL
Type "https://www.newgrounds.com/portal/view/218014"
Sleep 500ms
Enter

# Wait for the resolve + download
Sleep 4s

# Show the result
Sleep 3s

# Quit
Type "q"
Sleep 1s
