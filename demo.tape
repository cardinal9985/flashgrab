Output demo.gif

Set Shell "bash"
Set FontSize 16
Set Width 900
Set Height 520
Set Theme "Catppuccin Mocha"
Set Padding 20
Set TypingSpeed 50ms
Env PS1 "$ "

# Launch flashgrab
Type "flashgrab"
Enter
Sleep 2.5s

# Paste a Newgrounds URL
Type "https://www.newgrounds.com/portal/view/218014"
Sleep 300ms
Enter
Sleep 8s

# Done screen — shows Flashpoint match info
Sleep 2s

# Quit
Type "q"
Sleep 500ms
