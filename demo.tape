Output demo.gif

Set Shell "bash"
Set FontSize 16
Set Width 900
Set Height 520
Set Theme "Catppuccin Mocha"
Set Padding 20
Set TypingSpeed 50ms
Env PS1 "$ "

# Launch flashgrab
Type "flashgrab"
Enter
Sleep 2.5s

# Skip splash
Enter
Sleep 500ms

# Paste a Newgrounds URL
Type "https://www.newgrounds.com/portal/view/218014"
Sleep 300ms
Enter
Sleep 15s

# Linger on done screen
Sleep 3s

# Quit
Type "q"
Sleep 500ms
